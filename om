<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<style>

html{
scroll-behavior:smooth;
}

body{
font-family:'Inter',sans-serif;
margin:0;
color:#e6edf3;
background:#0f172a;
overflow-x:hidden;
}

/* движущийся фон */

.background{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
z-index:-1;

background:
radial-gradient(circle at 20% 30%, rgba(34,197,94,0.25), transparent 40%),
radial-gradient(circle at 80% 70%, rgba(20,184,166,0.25), transparent 40%),
radial-gradient(circle at 50% 50%, rgba(59,130,246,0.2), transparent 50%);

animation:movebg 12s infinite alternate;
}

@keyframes movebg{

0%{
transform:scale(1) translate(0px,0px);
}

50%{
transform:scale(1.2) translate(-40px,20px);
}

100%{
transform:scale(1.1) translate(30px,-30px);
}

}

/* header */

header{
text-align:center;
padding:80px;
background:rgba(0,0,0,0.45);
}

header h1{
font-size:46px;
margin:0;
}

/* navigation */

nav{
text-align:center;
padding:18px;
background:#0b0f14;
}

nav a{
color:#c9d1d9;
margin:15px;
text-decoration:none;
font-size:17px;
transition:0.3s;
}

nav a:hover{
color:#58f3c3;
}

/* sections */

section{
padding:70px;
max-width:1000px;
margin:auto;
}

/* services */

.services{
display:flex;
gap:25px;
flex-wrap:wrap;
}

.card{
background:#111827;
padding:30px;
border-radius:15px;
box-shadow:0 12px 30px rgba(0,0,0,0.5);
flex:1;
min-width:260px;
transition:0.3s;
}

.card:hover{
transform:translateY(-10px) scale(1.03);
}

.icon{
font-size:40px;
margin-bottom:10px;
}

/* button */

button{
background:linear-gradient(135deg,#22c55e,#14b8a6);
color:white;
border:none;
padding:12px 22px;
border-radius:8px;
cursor:pointer;
font-size:15px;
transition:0.3s;
margin-top:10px;
}

button:hover{
transform:scale(1.05);
box-shadow:0 8px 20px rgba(0,0,0,0.5);
}

/* price */

.price{
margin-top:10px;
font-weight:600;
color:#34d399;
}

/* contact */

.contact-box{
background:#111827;
padding:30px;
border-radius:12px;
}

/* telegram button floating */

.telegram{
position:fixed;
right:25px;
bottom:25px;
background:#229ED9;
color:white;
padding:14px 18px;
border-radius:50px;
cursor:pointer;
font-weight:600;
box-shadow:0 10px 25px rgba(0,0,0,0.5);
transition:0.3s;
}

.telegram:hover{
transform:scale(1.1);
}

/* footer */

footer{
text-align:center;
padding:25px;
background:#0b0f14;
margin-top:40px;
color:#9ca3af;
}

</style>
</head>

